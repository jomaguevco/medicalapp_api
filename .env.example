# =====================================================================
#  PLANTILLA DE VARIABLES DE ENTORNO
#
#  LOCAL:  copia este archivo como  .env  y pon tus datos de MySQL local.
#  NUBE:   define estas mismas variables en el panel del hosting
#          (Railway / Render / etc.). NO subas el archivo .env.
# =====================================================================

# --- Base de datos ---
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=medical_app_db
DB_PORT=3306

# Poner en true SOLO si el proveedor de BD exige TLS (Aiven, TiDB).
# En MySQL local o en la red interna de Railway: false
DB_SSL=false

# --- Seguridad ---
SECRET_KEY=USAT2026$$**01
